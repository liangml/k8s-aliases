alias kdnsl='kubectl describe namespaces -l'
alias kdnsf='kubectl describe namespaces --recursive -f'
alias kdelns='kubectl delete namespaces'
alias kdelnsn='kubectl delete namespaces --namespace'
alias kdelnsl='kubectl delete namespaces -l'
alias kdelnsf='kubectl delete namespaces --recursive -f'

# ── kubectl edit ──
alias ked='kubectl edit'
alias kedn='kubectl edit --namespace'

# ── kubectl rollout ──
alias kroll='kubectl rollout'
alias krollrestart='kubectl rollout restart'
alias krollstatus='kubectl rollout status'
alias krollhistory='kubectl rollout history'
alias krollundo='kubectl rollout undo'
alias krr='kubectl rollout restart'

# ── kubectl top ──
alias ktop='kubectl top'
alias ksystop='kubectl top --namespace=kube-system'

# ── context / namespace 切换 ──
alias kctx='kubectl config use-context'
alias kns='kubectl config set-context --current --namespace'

# ── 节点管理 ──
alias kdrain='kubectl drain'
alias kcordon='kubectl cordon'
alias kuncordon='kubectl uncordon'

# ── 标签 / 注解 ──
alias klabel='kubectl label'
alias kannotate='kubectl annotate'

# ── 文件复制 ──
alias kcp='kubectl cp'

# ── 其他 ──
alias ksys='kubectl --namespace=kube-system'
